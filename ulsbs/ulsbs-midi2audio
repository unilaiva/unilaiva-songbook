#
# Requires:
#   - bash version 3.0+  (for this wrapper)
#   - python3 version 3.11+
#   - ffmpeg and fluidsynth

# Ensure python3 is available (the version is checked by the python script)
if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is not installed or not found in PATH." >&2
  echo "" >&2
  echo "Please install Python 3.11+ and ensure 'python3' is on your PATH." >&2
  exit 1
fi

# Use the loop to get the canonical path (in case of symlink) to be compatible
# with ie MacOS, as readlink's -f argument is a GNU extension to POSIX and not
# supported on that OS.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

exec python3 "$SCRIPT_DIR/src/ulsbs/tools/midi2audio.py" "$@"
