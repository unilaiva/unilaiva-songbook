{
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\\[", "]"],
    ["\\(", "\\)"],
    ["\\beginsong", "\\endsong"],
    ["\\beginverse", "\\endverse"],
    ["\\mnbeginverse", "\\mnendverse"],
    ["\\beginrep", "\\endrep"],
    ["\\begin{translation}", "\\end{translation}"],
    ["\\begintranslation", "\\endtranslation"],
    ["\\begin{lilypond}", "\\end{lilypond}"],
    ["\\begin{songs}", "\\end{songs}"]
  ],

  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\\(", "\\)"]
  ],

  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],

  "folding": {
    "markers": {
      "start": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\beginsong\\b|\\\\beginverse\\b|\\\\mnbeginverse\\b|\\\\beginrep\\b|\\\\begin\\{translation\\}|\\\\begintranslation(?:\\[[^\\]]*\\])?|\\\\begin\\{lilypond\\}|\\\\begin\\{songs\\})",
      "end": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\endsong\\b|\\\\endverse\\b|\\\\mnendverse\\b|\\\\endrep\\b|\\\\end\\{translation\\}|\\\\endtranslation\\b|\\\\end\\{lilypond\\}|\\\\end\\{songs\\})"
    }
  },

  "indentationRules": {
    "increaseIndentPattern": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\beginsong\\b|\\\\beginverse\\b|\\\\mnbeginverse\\b|\\\\beginrep\\b|\\\\begin\\{translation\\}|\\\\begintranslation(?:\\[[^\\]]*\\])?|\\\\begin\\{lilypond\\}|\\\\begin\\{songs\\}).*$",
    "decreaseIndentPattern": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\endsong\\b|\\\\endverse\\b|\\\\mnendverse\\b|\\\\endrep\\b|\\\\end\\{translation\\}|\\\\endtranslation\\b|\\\\end\\{lilypond\\}|\\\\end\\{songs\\}).*$"
  },

  "onEnterRules": [
    {
      "beforeText": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\beginsong\\b|\\\\beginverse\\b|\\\\mnbeginverse\\b|\\\\beginrep\\b|\\\\begin\\{translation\\}|\\\\begintranslation(?:\\[[^\\]]*\\])?|\\\\begin\\{lilypond\\}|\\\\begin\\{songs\\}).*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\beginsong\\b|\\\\beginverse\\b|\\\\mnbeginverse\\b|\\\\beginrep\\b|\\\\begin\\{translation\\}|\\\\begintranslation(?:\\[[^\\]]*\\])?|\\\\begin\\{lilypond\\}|\\\\begin\\{songs\\}).*$",
      "afterText": "^(?:(?:[^%\\\\]|\\\\.|%(?=\\\\))*?)(\\\\endsong\\b|\\\\endverse\\b|\\\\mnendverse\\b|\\\\endrep\\b|\\\\end\\{translation\\}|\\\\endtranslation\\b|\\\\end\\{lilypond\\}|\\\\end\\{songs\\}).*$",
      "action": {
        "indent": "indentOutdent"
      }
    }
  ]
}
