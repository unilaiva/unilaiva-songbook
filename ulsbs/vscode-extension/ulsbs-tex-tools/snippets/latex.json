{
  "ULSBS chord definition": {
    "prefix": "\\[",
    "body": "\\[${1}]",
    "description": "Insert \\[ ... ]"
  },

  "begin{songs} ... end{songs}": {
    "prefix": [ "\\begin{songs}" ],
    "body": [
      "\\begin{songs}",
      "\t$0",
      "\\end{songs"
    ],
    "description": "Insert songs environment"
  },

  "beginsong ... endsong": {
    "prefix": [ "beginsong", "\\beginsong" ],
    "body": [
      "\\beginsong{${1:title}}",
      "\t$0",
      "\\endsong"
    ],
    "description": "Insert beginsong/endsong block"
  },

  "beginverse ... endverse": {
    "prefix": [ "beginverse", "\\beginverse" ],
    "body": [
      "\\beginverse",
      "\t$0",
      "\\endverse"
    ],
    "description": "Insert beginverse/endverse block"
  },

  "mnbeginverse ... mnendverse": {
    "prefix": [ "mnbeginverse", "\\mnbeginverse" ],
    "body": [
      "\\mnbeginverse",
      "\t$0",
      "\\mnendverse"
    ],
    "description": "Insert mnbeginverse/mnendverse block"
  },

  "beginrep ... endrep": {
    "prefix": [ "beginrep", "\\beginrep" ],
    "body": [
      "\\beginrep",
      "\t$0",
      "\\endrep"
    ],
    "description": "Insert beginrep/endrep block"
  },

  "begin{translation} ... end{translation}": {
    "prefix": [ "translation", "\\begin{translation}" ],
    "body": [
      "\\begin{translation}",
      "\t$0",
      "\\end{translation}"
    ],
    "description": "Insert translation environment"
  },

  "begin{lilypond} ... end{lilypond}": {
    "prefix": [ "lilypond", "\\begin{lilypond}" ],
    "body": [
      "\\begin{lilypond}",
      "\t$0",
      "\\end{lilypond}"
    ],
    "description": "Insert lilypond environment"
  },

  "begin{lilywrap+lilypond} ... end{lilypond+lilywrap}": {
    "prefix": [ "lilywrap", "\\begin{lilywrap}" ],
    "body": [
      "\\begin{lilywrap}\\begin{lilypond}",
      "\t$0",
      "\\end{lilypond}\\end{lilywrap}"
    ],
    "description": "Insert lilywrap + lilypond environment"
  }
}
