{
  "name": "ulsbs-tex-tools",
  "displayName": "ULSBS TeX Tools",
  "description": "Custom LaTeX support for ULSBS song macros",
  "version": "0.0.6",
  "publisher": "ulsbs",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "Lari Natri",
    "email": "lari.natri@iki.fi"
  },
  "icon": "images/ulsbs-vscode-extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/unilaiva/unilaiva-songbook",
    "directory": "ulsbs/vscode-extension/ulsbs-tex-tools"
  },
  "keywords": [
    "latex",
    "songbook",
    "lilypond",
    "ulsbs"
  ],
  "engines": {
    "vscode": "^1.112.0"
  },
  "main": "./extension.js",
  "browser": "./dist/web/extension.js",
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "latex",
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "latex",
        "path": "./snippets/latex.json"
      }
    ],
    "commands": [
      {
        "command": "ulsbsTexTools.compileCurrentContext",
        "title": "ULSBS: Compile current context…"
      },
      {
        "command": "ulsbsTexTools.compileAllSongbooks",
        "title": "ULSBS: Compile all songbooks…"
      },
      {
        "command": "ulsbsTexTools.refreshWorkspace",
        "title": "ULSBS: Refresh workspace index"
      },
      {
        "command": "ulsbsTexTools.openSongbook",
        "title": "ULSBS: Open songbook"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "ulsbsSongbooks",
          "name": "ULSBS",
          "icon": ""
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ulsbsTexTools.refreshWorkspace",
          "when": "view == ulsbsSongbooks",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ULSBS TeX Tools",
      "properties": {
        "ulsbsTexTools.enable": {
          "type": "string",
          "enum": ["auto", "on", "off"],
          "default": "auto",
          "description": "Enable ULSBS-specific features. 'auto' enables them only when a ULSBS workspace is detected."
        },
        "ulsbsTexTools.fileGlob": {
          "type": "string",
          "default": "**/*.*tex",
          "description": "Workspace glob for TeX-like documents."
        },
        "ulsbsTexTools.excludeGlob": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/temp/**",
            "**/ulsbs/assets/tex/**"
          ],
          "description": "Glob patterns for files and folders to exclude from ULSBS workspace scanning."
        },
        "ulsbsTexTools.compileCommand": {
          "type": "string",
          "default": "ulsbs/ulsbs-compile",
          "description": "Path to the ULSBS compile script, relative to the workspace root."
        },
        "ulsbsTexTools.askProfileOnCompile": {
          "type": "boolean",
          "default": true,
          "description": "Ask for a ULSBS profile when compiling."
        },
        "ulsbsTexTools.defaultProfile": {
          "type": "string",
          "default": "default",
          "description": "Fallback profile when not asking interactively."
        },
        "ulsbsTexTools.autoRefreshDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Refresh ULSBS diagnostics automatically on edits and saves."
        }
      }
    }
  },
  "scripts": {
    "compile-web": "node esbuild.web.mjs",
    "watch-web": "node esbuild.web.mjs --watch",
    "package": "npm run compile-web && vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0"
  }
}
